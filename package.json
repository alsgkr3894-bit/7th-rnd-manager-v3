{
  "name": "wonpay-rnd-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; sleep 1; rm -rf .next; next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "build:clean": "node scripts/clean-build.mjs",
    "start": "next start",
    "demo": "rm -rf .next && next build && next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "qa:smoke": "node scripts/smoke-qa.mjs",
    "qa:runtime": "node scripts/full-rt.mjs",
    "qa:prod": "node scripts/qa-prod.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=__tests__ --no-coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=__tests__ --no-coverage --runInBand"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.8.3"
  }
}
